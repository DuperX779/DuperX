        tabs[currentTab].Content.Visible = false
        tabs[currentTab].Button.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
    end
    tabs[tabName].Content.Visible = true
    tabs[tabName].Button.BackgroundColor3 = Color3.fromRGB(80, 80, 80)
    currentTab = tabName
